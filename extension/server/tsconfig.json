{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"target": "es2020",
		"module": "commonjs",
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"sourceMap": true,
		"outDir": "out",
		"rootDir": "./../..",
